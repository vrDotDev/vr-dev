        "completions": [
          "import os\nimport sys\nimport json\n\nx=1\nprint(x)\n"
        ],
        "ground_truth": {
          "max_violations": 0
        }
      },
      "expected": {
        "verdict": "FAIL",
        "max_score": 0.99
      }
    },
    {
      "name": "syntax_error_present",
