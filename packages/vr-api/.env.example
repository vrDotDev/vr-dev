# vr-api environment configuration
# Copy to .env and fill in values

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (NeonDB, Supabase, local, etc.)
DATABASE_URL=postgresql+asyncpg://vrdev:vrdev_local@postgres:5432/vrdev

# ── Authentication ───────────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# Leave empty to disable auth (development mode).
VR_API_KEYS=

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Max requests per minute per API key (default: 60)
VR_RATE_LIMIT_PER_MINUTE=60

# ── Evidence Retention ───────────────────────────────────────────────────────
# Days to keep evidence records before cleanup (default: 90)
VR_EVIDENCE_TTL_DAYS=90
