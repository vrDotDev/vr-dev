      "expected": { "verdict": "FAIL", "max_score": 0.0 }
    },
    {
      "name": "wrong_subject",
      "description": "Email exists but subject doesn't match",
      "input": {
        "completions": ["Sent email about returns."],
        "ground_truth": { "recipient": "customer@example.com", "subject_fragment": "nonexistent_subject_xyz" }
      },
      "expected": { "verdict": "FAIL", "max_score": 0.0 }
