{
  "description": "Negative fixtures \u2014 code with lint violations fails",
  "fixtures": [
    {
      "name": "unused_imports",
      "description": "Multiple unused imports trigger violations",
      "input": {
        "completions": [
          "import os\nimport sys\n\nprint('hello')\n"
        ],
        "ground_truth": {
          "max_violations": 0
        }
      },
      "expected": {
        "verdict": "FAIL",
        "max_score": 0.99
      }
