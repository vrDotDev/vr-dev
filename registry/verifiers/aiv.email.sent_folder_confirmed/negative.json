      "expected": { "verdict": "FAIL", "max_score": 0.0 }
    },
    {
      "name": "wrong_recipient",
      "description": "Email sent to wrong recipient",
      "input": {
        "completions": ["Sent confirmation."],
        "ground_truth": { "recipient": "wrong@example.com" }
